---
import site from "../config.json";
import "../styles/global.css";
import GdaLogo from "../components/GdaLogo.astro";

const { title, description } = Astro.props;
const fullTitle = title.includes(site.brand) ? title : `${title} | ${site.brand}`;
const path = Astro.url.pathname;

const links = [
  ["/", "Home"],
  ["/about", "About"],
  ["/programs", "Programs"],
  ["/free-training", "Free Training"],
  ["/book", "Book"],
  ["/contact", "Contact"],
] as const;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Great+Vibes&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-lg bg-gold px-4 py-2 text-sm font-bold text-ink opacity-0 focus:translate-y-0 focus:opacity-100 transition-all"
    >
      Skip to main
    </a>

    <header class="sticky top-0 z-50 border-b border-gold/15 bg-ink/96 backdrop-blur-md bg-grain">
      <div class="max-w-6xl mx-auto px-5 sm:px-8">
        <div class="flex min-h-[4.25rem] items-center justify-between gap-4 py-2">
          <a href="/" class="group flex items-center gap-3 shrink-0">
            <GdaLogo class="h-10 w-10 sm:h-11 sm:w-11 text-gold transition-transform group-hover:scale-[1.03]" />
            <span class="leading-tight">
              <span class="block font-display text-base sm:text-lg font-semibold text-ivory tracking-tight">
                Glorious Destiny
              </span>
              <span
                class="block text-[0.58rem] sm:text-[0.62rem] uppercase tracking-[0.28em] text-gold/75 font-sans font-semibold mt-0.5"
              >
                Advisory
              </span>
            </span>
          </a>

          <nav class="hidden lg:flex flex-wrap items-center justify-end gap-x-5 gap-y-2 text-sm font-sans font-semibold" aria-label="Main">
            {links.map(([href, label]) => (
              <a
                href={href}
                class:list={["text-ivory/88 hover:text-ivory transition-colors", path === href && "text-gold"]}
              >
                {label}
              </a>
            ))}
            <a
              href="/book"
              class="inline-flex items-center rounded-full bg-gold-shine px-5 py-2.5 text-ink text-sm font-bold shadow-lift hover:brightness-110 transition-all"
            >
              Start
            </a>
          </nav>

          <div class="lg:hidden flex items-center gap-2">
            <a
              href="/book"
              class="inline-flex rounded-full bg-gold-shine px-4 py-2 text-xs font-bold text-ink shadow-lift"
            >
              Book
            </a>
            <details class="relative group">
              <summary
                class="list-none cursor-pointer rounded-lg border border-gold/25 bg-charcoal/80 px-3 py-2 text-xs font-bold uppercase tracking-wider text-gold hover:bg-charcoal transition-colors"
              >
                Menu
              </summary>
              <div
                class="absolute right-0 mt-2 w-56 rounded-xl border border-gold/20 bg-panel/98 backdrop-blur-md py-2 shadow-lift z-50"
              >
                {links.map(([href, label]) => (
                  <a
                    href={href}
                    class:list={[
                      "block px-4 py-2.5 text-sm font-semibold text-ivory/90 hover:bg-gold/10 hover:text-ivory",
                      path === href && "text-gold bg-gold/5",
                    ]}
                  >
                    {label}
                  </a>
                ))}
              </div>
            </details>
          </div>
        </div>
      </div>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="relative bg-charcoal text-ivory/85 border-t border-gold/20 bg-grain overflow-hidden">
      <div class="pointer-events-none absolute inset-0 bg-dark-radial opacity-70" aria-hidden="true"></div>
      <div class="relative max-w-6xl mx-auto px-5 sm:px-8 py-14">
        <div class="grid md:grid-cols-2 gap-10 md:gap-16">
          <div>
            <div class="flex items-start gap-3">
              <GdaLogo class="h-10 w-10 shrink-0" />
              <div>
                <p class="font-display text-xl text-ivory leading-snug">{site.brand}</p>
                <p class="text-gold/90 text-sm mt-1 font-sans">{site.affiliation}</p>
              </div>
            </div>
            <p class="mt-5 text-sm text-ivory/70 font-sans leading-relaxed max-w-md">{site.tagline}</p>
          </div>
          <div>
            <p class="text-[0.65rem] uppercase tracking-[0.2em] text-gold/80 mb-3 font-sans">Explore</p>
            <ul class="space-y-2 text-sm font-sans text-ivory/75">
              <li><a href="/resources" class="hover:text-gold transition-colors">Financial Education</a></li>
              <li><a href="/testimonials" class="hover:text-gold transition-colors">Success stories</a></li>
              <li><a href="/apply" class="hover:text-gold transition-colors">Mentorship application</a></li>
              <li><a href="/legal" class="hover:text-gold transition-colors">Disclosures &amp; compliance</a></li>
              <li><a href="/privacy" class="hover:text-gold transition-colors">Privacy Policy</a></li>
              <li><a href="/terms" class="hover:text-gold transition-colors">Terms of Use</a></li>
            </ul>
          </div>
        </div>

        <div
          class="mt-12 pt-10 border-t border-ivory/10 text-xs text-ivory/55 font-sans leading-relaxed max-w-4xl space-y-3"
          role="note"
        >
          <p>
            <strong class="text-ivory/70">Independent entity.</strong> Glorious Destiny Advisory is an independent
            entity. {site.principal} is a licensed financial professional with World Financial Group (WFG).
          </p>
          <p>
            This website is for <strong class="text-ivory/70">educational purposes only</strong> and does not
            constitute financial, legal, or tax advice. Results may vary. Consult a licensed professional for your
            specific situation.
          </p>
          <p class="text-ivory/45">&copy; {new Date().getFullYear()} {site.brand}. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
