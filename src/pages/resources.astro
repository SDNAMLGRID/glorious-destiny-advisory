---
import GlobalLayout from "../layouts/GlobalLayout.astro";

const topics = [
  {
    title: "What “financial foundation” actually means",
    desc: "Cash flow, protection, and habits—before optimization.",
    href: "#",
  },
  {
    title: "Income protection in plain language",
    desc: "Why the paycheck is the engine—and what to watch for.",
    href: "#",
  },
  {
    title: "Legacy beyond a will",
    desc: "Values, conversations, and structures that outlive a document.",
    href: "#",
  },
];
---

<GlobalLayout title="Financial Education" description="Articles and resources from Glorious Destiny Advisory—education first.">
  <section class="relative bg-ink text-ivory py-20 sm:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-dark-radial opacity-60 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-5 sm:px-8">
      <h1 class="font-display text-4xl sm:text-5xl font-semibold">Financial Education</h1>
      <p class="mt-6 text-ivory/75 font-sans text-lg leading-relaxed">
        Short reads to nurture leads and reinforce authority—always educational, never hype.
      </p>
    </div>
  </section>

  <section class="py-16 bg-ivory border-t border-ink/5">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 grid md:grid-cols-3 gap-8">
      {topics.map((t) => (
        <article class="rounded-2xl border border-ink/10 bg-white p-8 shadow-card flex flex-col hover:shadow-lift hover:-translate-y-0.5 transition-all duration-300">
          <h2 class="font-display text-xl font-semibold text-ink leading-snug">{t.title}</h2>
          <p class="mt-3 font-sans text-muted text-sm leading-relaxed flex-1">{t.desc}</p>
          <a href={t.href} class="mt-6 inline-flex font-sans text-sm font-bold text-gold-deep hover:text-ink">
            Read article →
          </a>
        </article>
      ))}
    </div>
    <p class="max-w-2xl mx-auto px-5 mt-12 text-center text-sm text-muted font-sans">
      Phase 2: migrate these to Astro Content Collections or MDX for real posts and SEO-friendly URLs.
    </p>
  </section>
</GlobalLayout>
