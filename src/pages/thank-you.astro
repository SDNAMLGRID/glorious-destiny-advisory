---
import GlobalLayout from "../layouts/GlobalLayout.astro";
---

<GlobalLayout title="Thank You" description="You're registered—next steps from Glorious Destiny Advisory.">
  <section class="min-h-[65vh] flex items-center justify-center px-5 py-20 bg-ivory">
    <div class="max-w-lg text-center">
      <p class="text-gold font-sans text-sm font-bold uppercase tracking-widest">Thank you</p>
      <h1 class="mt-4 font-display text-3xl sm:text-4xl font-semibold text-ink">You’re in.</h1>
      <p class="mt-6 font-sans text-body/90 leading-relaxed" id="thank-sub">
        Check your inbox for next steps. If you don’t see an email within a few minutes, check spam—or reach out via
        Contact.
      </p>
      <p class="mt-4 text-sm text-muted font-sans leading-relaxed">
        While you wait: skim the <a href="/resources" class="text-gold-deep font-semibold hover:underline">resources hub</a>
        or pick a time for a complimentary
        <a href="/book" class="text-gold-deep font-semibold hover:underline"> conversation</a>.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/book" class="inline-flex rounded-full bg-gold-shine px-8 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all">
          Book a conversation
        </a>
        <a href="/" class="inline-flex rounded-full border border-ink/15 px-8 py-3.5 text-sm font-semibold text-ink hover:bg-sand transition-colors">
          Back home
        </a>
      </div>
    </div>
  </section>
  <script is:inline>
    (function () {
      try {
        var p = new URLSearchParams(window.location.search);
        var src = p.get("source");
        var el = document.getElementById("thank-sub");
        if (!el) return;
        if (src === "free-training") {
          el.textContent =
            "Thanks for registering. You’ll receive the training link and follow-up resources shortly. If anything looks off, contact us directly.";
        } else if (src === "mentorship-apply") {
          el.textContent =
            "Application received. The team will review and follow up with next steps if there’s a fit.";
        } else if (src === "contact") {
          el.textContent = "Thanks for your message. We’ll reply as soon as we can.";
        }
      } catch (_) {}
    })();
  </script>
</GlobalLayout>
