---
import GlobalLayout from "../layouts/GlobalLayout.astro";
import site from "../config.json";

const formEndpoint = site.formEndpoint?.trim();
const formAction = formEndpoint || `mailto:${site.email}`;
const formEncoding = formEndpoint ? "application/x-www-form-urlencoded" : "text/plain";
---

<GlobalLayout title="Apply for Mentorship" description="Apply for Wealth & Leadership Mentorship with Glorious Destiny Advisory.">
  <section class="relative bg-ink text-ivory py-20 sm:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-dark-radial opacity-50 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-semibold">Mentorship Application</h1>
      <p class="mt-6 text-ivory/75 font-sans text-lg leading-relaxed">
        A short form helps us honor your time—and ensure this program is the right season for you.
      </p>
      <p class="mt-4 text-ivory/60 font-sans text-sm max-w-xl mx-auto leading-relaxed">
        Strong fits often look like: you want accountability, you can protect weekly focus blocks, and you are open to
        both practical strategy and leadership growth—not either-or.
      </p>
    </div>
  </section>

  <section class="py-16 bg-ivory">
    <div class="max-w-xl mx-auto px-5 sm:px-8">
      <form class="space-y-5" method="post" action={formAction} enctype={formEncoding}>
        <input type="hidden" name="source" value="mentorship-apply" />
        <div>
          <label class="block text-sm font-semibold text-ink mb-1">Name</label>
          <input type="text" name="name" required class="w-full rounded-xl border border-ink/15 px-4 py-3 font-sans bg-white" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-ink mb-1">Email</label>
          <input type="email" name="email" required class="w-full rounded-xl border border-ink/15 px-4 py-3 font-sans bg-white" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-ink mb-1">What are you working toward in the next 12 months?</label>
          <textarea name="goals" rows={4} class="w-full rounded-xl border border-ink/15 px-4 py-3 font-sans bg-white"></textarea>
        </div>
        <div>
          <label class="block text-sm font-semibold text-ink mb-1">Readiness to invest time (1–10)</label>
          <input type="number" name="readiness" min="1" max="10" class="w-full rounded-xl border border-ink/15 px-4 py-3 font-sans bg-white" />
        </div>
        <button type="submit" class="w-full rounded-full bg-gold-shine py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all">
          Submit application
        </button>
      </form>
      <p class="mt-6 text-xs text-muted font-sans">
        Applications are reviewed for fit, timing, and readiness. Please avoid sharing confidential financial documents
        in this form.
      </p>
    </div>
  </section>
</GlobalLayout>
