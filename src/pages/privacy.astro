---
import GlobalLayout from "../layouts/GlobalLayout.astro";
import site from "../config.json";
---

<GlobalLayout title="Privacy Policy" description="Privacy policy for Glorious Destiny Advisory.">
  <section class="py-20 bg-ivory">
    <div class="max-w-3xl mx-auto px-5 sm:px-8">
      <h1 class="font-display text-4xl font-semibold text-ink">Privacy Policy</h1>
      <p class="mt-4 text-sm text-muted font-sans">Last updated: {site.legalLastUpdated}</p>

      <div class="mt-12 space-y-8 font-sans text-body/90 leading-relaxed">
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Who we are</h2>
          <p class="mt-3">
            This policy describes how {site.brand} (“we”, “us”) collects, uses, and shares information when you use this
            website.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Information we collect</h2>
          <ul class="mt-3 list-disc pl-6 space-y-2">
            <li>Contact details you submit through forms (such as name, email address, and message content).</li>
            <li>Basic technical data from your browser (such as IP address, device type, and pages viewed) via analytics tools if enabled.</li>
            <li>Scheduling information if you book through an embedded third-party calendar provider.</li>
          </ul>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">How we use information</h2>
          <p class="mt-3">
            We use information to respond to inquiries, deliver educational resources you request, improve the website,
            and comply with law. We do not sell your personal information.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Retention</h2>
          <p class="mt-3">
            We retain messages and form submissions only as long as needed for the purposes above or as required by
            law. Ask us to delete your contact record where applicable law allows.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Third parties</h2>
          <p class="mt-3">
            Email marketing platforms, form handlers, analytics providers, and scheduling tools may process data on
            our behalf under their own privacy policies. Review those services before submitting sensitive information.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Contact</h2>
          <p class="mt-3">
            Questions about privacy: <a href={`mailto:${site.email}`} class="text-gold-deep font-semibold hover:underline">{site.email}</a>
          </p>
        </section>
        <p class="text-sm text-muted border-t border-ink/10 pt-8">
          This policy may be updated as services, tools, or legal requirements change.
        </p>
      </div>
    </div>
  </section>
</GlobalLayout>
