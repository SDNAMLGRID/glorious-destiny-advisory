---
import GlobalLayout from "../layouts/GlobalLayout.astro";
---

<GlobalLayout title="Success Stories" description="Testimonials and transformations from Glorious Destiny Advisory.">
  <section class="bg-ink text-ivory py-20 sm:py-24">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-semibold">Success Stories</h1>
      <p class="mt-6 text-ivory/75 font-sans text-lg">Real people. Real shifts in clarity and confidence.</p>
    </div>
  </section>
  <section class="py-16 bg-ivory">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 space-y-10">
      <p class="font-sans text-body/90 text-center">
        Add full testimonials with first name + initial, photo (with permission), and context. Until then, the homepage
        features soft proof quotes.
      </p>
      <div class="text-center">
        <a href="/book" class="inline-flex rounded-full bg-gold px-6 py-3 text-sm font-bold text-ink hover:brightness-110 transition-all">
          Book your session
        </a>
      </div>
    </div>
  </section>
</GlobalLayout>
