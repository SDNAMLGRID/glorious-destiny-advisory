---
import GlobalLayout from "../layouts/GlobalLayout.astro";

const stories = [
  {
    quote:
      "I did not realize how much anxiety was coming from unanswered questions. One conversation gave me language for what I was feeling—and a short list of what to do next.",
    name: "Education session attendee",
  },
  {
    quote:
      "The mentorship rhythm helped me stop starting over every month. Small wins stacked, and my spouse and I are finally talking about money without tension.",
    name: "Mentorship participant",
  },
  {
    quote:
      "I appreciated that faith was not treated as a sidebar. Stewardship, protection, and generosity finally sit in the same frame.",
    name: "Advisory conversation attendee",
  },
];
---

<GlobalLayout title="Success Stories" description="Testimonials and transformations from Glorious Destiny Advisory.">
  <section class="relative bg-ink text-ivory py-20 sm:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-grain opacity-15 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-semibold">Success Stories</h1>
      <p class="mt-6 text-ivory/75 font-sans text-lg max-w-2xl mx-auto leading-relaxed">
        Voices from early education sessions—shared to encourage, not to promise a specific outcome. Your story will be
        yours.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-ivory">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 grid md:grid-cols-3 gap-8">
      {stories.map((s) => (
        <blockquote class="rounded-2xl border border-ink/10 bg-white p-8 shadow-card">
          <p class="font-display text-lg text-ink/90 italic leading-relaxed">“{s.quote}”</p>
          <footer class="mt-6 text-xs uppercase tracking-wider text-muted font-sans">{s.name}</footer>
        </blockquote>
      ))}
    </div>
    <div class="max-w-3xl mx-auto px-5 sm:px-8 mt-12 text-center font-sans text-muted text-sm leading-relaxed">
      <p>
        Stories are shared in an education-first spirit. Results vary, and no testimonial should be read as a promise
        of financial outcome.
      </p>
      <a href="/book" class="mt-8 inline-flex rounded-full bg-gold-shine px-8 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all">
        Book your session
      </a>
    </div>
  </section>
</GlobalLayout>
