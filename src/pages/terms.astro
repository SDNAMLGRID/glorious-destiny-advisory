---
import GlobalLayout from "../layouts/GlobalLayout.astro";
import site from "../config.json";
---

<GlobalLayout title="Terms of Use" description="Terms of use for Glorious Destiny Advisory.">
  <section class="py-20 bg-ivory">
    <div class="max-w-3xl mx-auto px-5 sm:px-8">
      <h1 class="font-display text-4xl font-semibold text-ink">Terms of Use</h1>
      <p class="mt-4 text-sm text-muted font-sans">Last updated: {site.legalLastUpdated}</p>

      <div class="mt-12 space-y-8 font-sans text-body/90 leading-relaxed">
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Agreement</h2>
          <p class="mt-3">
            By accessing this website, you agree to these terms. If you do not agree, do not use the site. {site.brand}
            may update these terms; continued use after changes constitutes acceptance.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Educational content</h2>
          <p class="mt-3">
            All materials are for general education. They are not an offer to buy or sell securities or insurance
            products in any jurisdiction where prohibited. {site.principal} is a licensed financial professional with
            WFG; see disclosures on the Legal page.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">No warranties</h2>
          <p class="mt-3">
            The site is provided “as is” without warranties of any kind. We do not warrant uninterrupted or error-free
            access.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Limitation of liability</h2>
          <p class="mt-3">
            To the fullest extent permitted by law, {site.brand} and its principals are not liable for indirect,
            incidental, or consequential damages arising from your use of the site or reliance on its content.
          </p>
        </section>
        <section>
          <h2 class="font-display text-xl font-semibold text-ink">Governing law</h2>
          <p class="mt-3">
            These terms are governed by the laws of the State of Ohio (update if your counsel advises a different
            venue), without regard to conflict-of-law rules.
          </p>
        </section>
        <p class="text-sm text-muted border-t border-ink/10 pt-8">
          These terms may be updated as services, tools, or legal requirements change.
        </p>
      </div>
    </div>
  </section>
</GlobalLayout>
