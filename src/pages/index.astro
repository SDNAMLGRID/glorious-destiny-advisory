---
import GlobalLayout from "../layouts/GlobalLayout.astro";
import AdvisoryRule from "../components/AdvisoryRule.astro";
import GdaLogo from "../components/GdaLogo.astro";
import site from "../config.json";

const learnItems = [
  "How cash flow, protection, and positioning work together before you chase “the next big thing”",
  "Plain-language context for growing and defending wealth—so choices feel informed, not rushed",
  "Leadership habits that turn good intentions into follow-through at home and at work",
  "Legacy as stewardship: values, conversations, and structures that outlast any single account",
  "How to align calling and calendar with a financial strategy you can explain in one sentence",
];
---

<GlobalLayout
  title={site.brand}
  description="Faith-forward financial education—clarity, protection, and legacy-minded strategy with Dr Gloria Ajayi. Book a complimentary educational conversation."
>
  <!-- 1. Hero — split layout, advisory office imagery -->
  <section class="relative min-h-[min(100dvh,900px)] flex flex-col lg:flex-row bg-ink text-ivory overflow-hidden">
    <div class="relative w-full lg:w-[46%] min-h-[300px] sm:min-h-[380px] lg:min-h-0 lg:max-w-none shrink-0">
      <img
        src="/images/gda/Professional%20advisory%20meeting%20in%20a%20modern%20office.png"
        alt="Professional advisory meeting in a modern office"
        width="1200"
        height="900"
        class="absolute inset-0 h-full w-full object-cover object-[30%_center] lg:object-[35%_center]"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-ink/20 via-transparent to-ink lg:via-ink/30 lg:to-ink"
        aria-hidden="true"
      ></div>
      <div class="absolute inset-0 bg-grain opacity-40 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
    </div>

    <div
      class="relative flex flex-1 flex-col justify-center px-6 sm:px-10 lg:pl-10 lg:pr-14 xl:pr-20 py-16 lg:py-24 bg-ink bg-dark-radial bg-grain"
    >
      <div class="pointer-events-none absolute inset-0 opacity-[0.07]" aria-hidden="true" style="background-image: radial-gradient(circle at 20% 30%, rgba(255,220,160,0.9) 0%, transparent 35%), radial-gradient(circle at 80% 60%, rgba(201,165,74,0.5) 0%, transparent 40%);"></div>

      <div class="relative max-w-xl">
        <p class="font-script text-2xl sm:text-3xl md:text-4xl text-gold-bright/95 leading-none mb-1">{site.principal}</p>
        <div class="flex items-center gap-3 mt-4 mb-2">
          <GdaLogo class="h-12 w-12 sm:h-14 sm:w-14" />
          <p class="font-brand text-[0.62rem] sm:text-xs uppercase tracking-[0.28em] text-gold/80 font-semibold leading-tight">
            Glorious Destiny<br /><span class="text-ivory/90">Advisory</span>
          </p>
        </div>
        <AdvisoryRule label="Wealth · Leadership · Legacy" class="justify-start mt-2 mb-8 max-w-md" />

        <h1 class="font-display text-[2rem] sm:text-4xl lg:text-[2.75rem] font-semibold leading-[1.1] tracking-tight">
          Steward your income. Strengthen your leadership. Leave a legacy you’re proud to hand down.
        </h1>
        <p class="mt-8 text-base sm:text-lg text-ivory/78 font-sans leading-relaxed">
          Faith-forward education and mentorship—so your next step is grounded in understanding, not noise. {site.brand}
          meets you where you are and helps you see protection, growth, and legacy in plain language.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/free-training"
            class="inline-flex items-center justify-center rounded-full bg-gold-shine px-8 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all"
          >
            Start Your Journey
          </a>
          <a
            href="/book"
            class="inline-flex items-center justify-center rounded-full border border-gold/35 bg-ivory/5 px-8 py-3.5 text-sm font-semibold text-ivory hover:bg-ivory/10 transition-colors"
          >
            Book a Free Consultation
          </a>
        </div>
        <p class="mt-12 text-xs sm:text-sm text-ivory/50 font-sans border-t border-gold/15 pt-8 max-w-lg leading-relaxed">
          {site.affiliation}
        </p>
      </div>
    </div>
  </section>

  <!-- Brand strip -->
  <section class="py-14 sm:py-16 bg-charcoal border-y border-gold/15" aria-label="Glorious Destiny Advisory">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <div class="overflow-hidden border border-gold/25 shadow-goldring bg-ivory">
        <img
          src="/images/gda/logo-horizontal-dark.png"
          alt="Glorious Destiny Advisory"
          width="1400"
          height="420"
          class="w-full h-auto object-contain object-center"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- 2. Why we exist (dual lens — inspired by clarity / protection framing) -->
  <section class="py-20 sm:py-24 bg-ivory border-t border-ink/5" aria-labelledby="why-heading">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <p class="text-center text-xs font-bold uppercase tracking-[0.22em] text-gold-deep font-sans mb-3">Why we exist</p>
      <h2 id="why-heading" class="font-display text-3xl sm:text-4xl font-semibold text-ink text-center max-w-3xl mx-auto leading-tight">
        Hope-forward clarity before complexity. Protection before guesswork.
      </h2>
      <p class="mt-6 text-lg text-body/85 font-sans text-center max-w-2xl mx-auto leading-relaxed">
        Most households are not short on effort—they are short on a calm place to learn how pieces fit together. {site.brand}
        exists so you can understand the “why” behind strategy, then move at a pace that honors your faith, your family, and your season of life.
      </p>
      <div class="mt-14 grid md:grid-cols-2 gap-8 md:gap-10">
        <div class="rounded-2xl border border-ink/10 bg-white p-8 shadow-card">
          <h3 class="font-display text-xl font-semibold text-ink border-b border-gold/25 pb-3 mb-4">What quietly drains confidence</h3>
          <ul class="space-y-3 font-sans text-body/85 leading-relaxed">
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>Jargon-heavy advice that never connects to your actual cash flow and priorities</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>Old accounts and old assumptions still steering the ship after life has changed</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>Protection gaps on the one asset that funds everything else: your income</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>Confusing “busy with money” with a coordinated plan for flexibility and legacy</span>
            </li>
          </ul>
        </div>
        <div class="rounded-2xl border border-ink/10 bg-white p-8 shadow-card">
          <h3 class="font-display text-xl font-semibold text-ink border-b border-gold/25 pb-3 mb-4">What we believe instead</h3>
          <ul class="space-y-3 font-sans text-body/85 leading-relaxed">
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>Education first: you deserve to know why something is suggested—not just that it exists</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>Leadership and stewardship belong in the same conversation as statements and spreadsheets</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>Peace of mind is a design problem: protection, positioning, and purpose working together</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold shrink-0">◆</span>
              <span>One faithful next step beats a stack of unfinished intentions</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Get clarity first -->
  <section class="py-14 sm:py-16 bg-charcoal border-y border-gold/15" aria-labelledby="clarity-strip-heading">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="rounded-2xl border border-gold/20 bg-ink/80 p-8 md:p-10 flex flex-col lg:flex-row items-center justify-between gap-8">
        <div class="text-center lg:text-left">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-gold font-sans mb-2">Start with clarity</p>
          <h2 id="clarity-strip-heading" class="font-display text-2xl md:text-3xl font-semibold text-ivory leading-tight">
            Learn first—then decide what deserves a deeper conversation
          </h2>
          <p class="mt-3 font-sans text-ivory/75 max-w-2xl leading-relaxed">
            Browse the education hub, register for the free training, or book a complimentary conversation. Each path is
            designed to reduce overwhelm and replace mystery with plain-language context.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 w-full lg:w-auto shrink-0">
          <a
            href="/resources"
            class="inline-flex items-center justify-center rounded-full bg-gold-shine px-7 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all w-full sm:w-auto text-center"
          >
            Open resources
          </a>
          <a
            href="/free-training"
            class="inline-flex items-center justify-center rounded-full border border-gold/35 px-7 py-3.5 text-sm font-semibold text-ivory hover:bg-ivory/5 transition-colors w-full sm:w-auto text-center"
          >
            Free training
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. The shift -->
  <section class="py-20 sm:py-24 bg-sand/70 border-t border-ink/5" aria-labelledby="shift-heading">
    <div class="max-w-3xl mx-auto px-5 sm:px-8">
      <h2 id="shift-heading" class="font-display text-3xl sm:text-4xl font-semibold text-ink text-center leading-tight">
        A calmer way to move forward
      </h2>
      <div class="mt-10 space-y-6 font-sans text-lg text-body/90 leading-relaxed">
        <p class="text-xl font-medium text-ink text-center">
          That’s where {site.principal} comes in.
        </p>
        <p>
          Through {site.brand}, she walks alongside individuals and families to:
        </p>
        <ul class="space-y-3">
          <li class="flex gap-3">
            <span class="text-gold mt-1 shrink-0">◆</span>
            <span>Name the gap between where you are and where you want to be—without shame</span>
          </li>
          <li class="flex gap-3">
            <span class="text-gold mt-1 shrink-0">◆</span>
            <span>Build structured, education-first strategies you can repeat and teach at home</span>
          </li>
          <li class="flex gap-3">
            <span class="text-gold mt-1 shrink-0">◆</span>
            <span>Grow leadership capacity alongside financial confidence</span>
          </li>
          <li class="flex gap-3">
            <span class="text-gold mt-1 shrink-0">◆</span>
            <span>Anchor decisions in purpose so “success” still feels like you on your best day</span>
          </li>
        </ul>
        <p class="text-center font-medium text-ink pt-2">
          This isn’t a script—it’s a relationship built for the long arc.<br />
          <span class="text-body/80 font-normal">Guided, principled, and paced for real life.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- 5. Authority — education-first context imagery -->
  <section class="py-20 sm:py-24 bg-ink text-ivory relative overflow-hidden" aria-labelledby="meet-heading">
    <div class="absolute inset-0 bg-grain opacity-[0.12] pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-5 sm:px-8 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="order-2 lg:order-1">
        <div class="rounded-2xl overflow-hidden border border-gold/25 shadow-goldring bg-charcoal max-w-md mx-auto lg:mx-0">
          <img
            src="/images/gda/Focus%20on%20success%20and%20strategy.png"
            alt="Focus on success and strategy in a professional setting"
            width="900"
            height="1200"
            class="w-full h-auto object-cover object-[center_22%]"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <AdvisoryRule label="Meet your guide" class="justify-start mb-6" />
        <h2 id="meet-heading" class="font-display text-3xl sm:text-4xl font-semibold text-ivory leading-tight">
          Meet {site.principal}
        </h2>
        <p class="mt-8 font-sans text-lg text-ivory/80 leading-relaxed">
          {site.principal} is a licensed financial professional with World Financial Group (WFG), dedicated to
          empowering individuals through financial education, leadership development, and purpose-driven guidance.
        </p>
        <p class="mt-8 border-l-2 border-gold/60 pl-6 font-sans text-lg italic text-ivory/85 leading-relaxed">
          {site.brand} is built on a simple premise: every household deserves a quiet place to learn—where questions are
          welcome, language is plain, and faith and stewardship sit in the blueprint, not at the margins.
        </p>
        <p class="mt-6 font-sans text-lg text-ivory/80 leading-relaxed">
          <span class="text-gold font-semibold">Her mission is simple:</span><br />
          Help people move from uncertainty to clarity—and from survival to legacy—with integrity and follow-through.
        </p>
        <p class="mt-10">
          <a href="/about" class="inline-flex font-sans text-sm font-bold text-gold hover:text-gold-bright underline underline-offset-4 transition-colors">
            Read her story →
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- 6. What you'll learn -->
  <section class="py-20 sm:py-24 bg-ivory border-t border-ink/5" aria-labelledby="learn-heading">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <h2 id="learn-heading" class="font-display text-3xl sm:text-4xl font-semibold text-ink text-center max-w-3xl mx-auto leading-tight">
        What You’ll Learn Inside {site.brand}
      </h2>
      <ul class="mt-14 max-w-2xl mx-auto space-y-4 font-sans text-lg text-body/90">
        {learnItems.map((line) => (
          <li class="flex gap-4 items-start rounded-xl border border-ink/10 bg-white/90 px-6 py-4 shadow-card hover:shadow-lift hover:-translate-y-0.5 transition-all duration-300">
            <span class="text-gold mt-0.5 shrink-0" aria-hidden="true">◆</span>
            <span>{line}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 7. Programs -->
  <section class="py-20 sm:py-24 bg-sand/50 border-t border-ink/5" aria-labelledby="programs-heading">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <h2 id="programs-heading" class="font-display text-3xl sm:text-4xl font-semibold text-ink text-center leading-tight">
        Start Where You Are
      </h2>
      <div class="mt-14 grid md:grid-cols-3 gap-8">
        <article class="rounded-2xl border border-ink/10 bg-ivory p-8 shadow-card hover:shadow-lift hover:-translate-y-1 transition-all duration-300 flex flex-col border-gold-soft">
          <p class="text-gold text-xs font-bold uppercase tracking-widest font-sans">Entry</p>
          <h3 class="mt-3 font-display text-xl font-semibold text-ink">Free Financial Education Session</h3>
          <p class="mt-4 font-sans text-muted leading-relaxed flex-1">
            A no-pressure look at priorities, blind spots, and what “peace of mind” could look like in practical terms.
          </p>
          <a href="/book" class="mt-8 inline-flex font-sans text-sm font-bold text-gold-deep hover:text-ink underline underline-offset-4">
            Book Free Session →
          </a>
        </article>
        <article class="rounded-2xl border border-gold/35 bg-ivory p-8 shadow-goldring hover:-translate-y-1 transition-all duration-300 flex flex-col">
          <p class="text-gold text-xs font-bold uppercase tracking-widest font-sans">Growth</p>
          <h3 class="mt-3 font-display text-xl font-semibold text-ink">Wealth &amp; Leadership Mentorship</h3>
          <p class="mt-4 font-sans text-muted leading-relaxed flex-1">
            Rhythmic coaching for the season you’re in—wealth habits, leadership edges, and accountability that respects your calendar.
          </p>
          <a href="/apply" class="mt-8 inline-flex font-sans text-sm font-bold text-gold-deep hover:text-ink underline underline-offset-4">
            Apply Now →
          </a>
        </article>
        <article class="rounded-2xl border border-ink/10 bg-ivory p-8 shadow-card hover:shadow-lift hover:-translate-y-1 transition-all duration-300 flex flex-col border-gold-soft">
          <p class="text-gold text-xs font-bold uppercase tracking-widest font-sans">Personal</p>
          <h3 class="mt-3 font-display text-xl font-semibold text-ink">One-on-One Advisory</h3>
          <p class="mt-4 font-sans text-muted leading-relaxed flex-1">
            Tailored education and strategy conversations aligned to your goals, values, and timeline—not a one-size-fits-all script.
          </p>
          <a href="/book" class="mt-8 inline-flex font-sans text-sm font-bold text-gold-deep hover:text-ink underline underline-offset-4">
            Schedule Consultation →
          </a>
        </article>
      </div>
      <p class="mt-10 text-center">
        <a href="/programs" class="font-sans text-sm font-semibold text-ink/70 hover:text-gold-deep transition-colors">
          View all programs →
        </a>
      </p>
    </div>
  </section>

  <!-- 8. Social proof -->
  <section class="py-20 sm:py-24 bg-ivory border-t border-ink/5" aria-labelledby="proof-heading">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <h2 id="proof-heading" class="font-display text-3xl sm:text-4xl font-semibold text-ink text-center leading-tight">
        Real People. Real Transformation.
      </h2>
      <p class="mt-4 text-center text-sm text-muted font-sans max-w-xl mx-auto">
        Early reflections from education-first sessions—full names and longer stories are added with permission as they
        become available.
      </p>
      <div class="mt-14 grid md:grid-cols-3 gap-8">
        {[
          {
            q: "She explained things in human language—no pressure, no rush. For the first time I could see my whole picture on one page.",
            f: "Education session participant",
          },
          {
            q: "I came in overwhelmed and left with three priorities I could actually act on this month. That kind of clarity is rare.",
            f: "Mentorship participant",
          },
          {
            q: "Faith and finances finally feel like they belong in the same conversation. I wish I had found this sooner.",
            f: "Advisory conversation attendee",
          },
        ].map(({ q, f }) => (
          <blockquote class="rounded-2xl border border-ink/10 bg-white p-8 shadow-card">
            <p class="font-display text-lg text-ink/90 italic leading-relaxed">“{q}”</p>
            <footer class="mt-6 text-xs uppercase tracking-wider text-muted font-sans">{f}</footer>
          </blockquote>
        ))}
      </div>
      <p class="mt-10 text-center">
        <a href="/testimonials" class="font-sans text-sm font-semibold text-gold-deep hover:text-ink transition-colors">
          More success stories →
        </a>
      </p>
    </div>
  </section>

  <!-- Secondary visual — professional office meeting -->
  <section class="py-0 bg-ink" aria-label="Professional advisory context">
    <img
      src="/images/gda/Professional%20meeting%20in%20a%20modern%20office.png"
      alt="Professional meeting in a modern office"
      width="1600"
      height="700"
      class="w-full h-auto max-h-[420px] sm:max-h-[520px] object-cover object-center opacity-95"
      loading="lazy"
      decoding="async"
    />
  </section>

  <!-- 9. Conversation offer -->
  <section class="py-16 sm:py-20 bg-sand/60 border-t border-ink/5" aria-labelledby="conversation-heading">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.22em] text-gold-deep font-sans mb-3">Ready when you are</p>
      <h2 id="conversation-heading" class="font-display text-3xl sm:text-4xl font-semibold text-ink leading-tight">
        Complimentary educational conversation
      </h2>
      <p class="mt-5 font-sans text-lg text-body/85 leading-relaxed">
        A structured, calm conversation to understand where you are, what worries you most, and what a realistic next step
        looks like—without a jargon wall.
      </p>
      <ul class="mt-8 text-left max-w-xl mx-auto space-y-3 font-sans text-body/85">
        <li class="flex gap-2">
          <span class="text-gold shrink-0">◆</span>
          <span>A clearer picture of gaps that often hide in plain sight</span>
        </li>
        <li class="flex gap-2">
          <span class="text-gold shrink-0">◆</span>
          <span>Plain-language context so you can compare options with confidence</span>
        </li>
        <li class="flex gap-2">
          <span class="text-gold shrink-0">◆</span>
          <span>A recommended path forward when it’s a fit—including the courage to “not yet” when it isn’t</span>
        </li>
      </ul>
      <div class="mt-10">
        <a
          href="/book"
          class="inline-flex items-center justify-center rounded-full bg-gold-shine px-8 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all"
        >
          Book your conversation
        </a>
      </div>
    </div>
  </section>

  <!-- 10. Final CTA -->
  <section class="relative py-20 sm:py-28 bg-ink text-ivory overflow-hidden border-t border-gold/15" aria-labelledby="close-heading">
    <div class="pointer-events-none absolute inset-0 bg-grain opacity-20" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 bg-dark-radial opacity-80" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <h2 id="close-heading" class="font-display text-3xl sm:text-4xl font-semibold leading-tight">
        The next chapter starts with one brave, informed step
      </h2>
      <p class="mt-8 font-sans text-lg text-ivory/75 leading-relaxed">
        The distance between today and the future you want is not perfection—it is consistent, well-lit action.
      </p>
      <p class="mt-4 font-sans text-lg text-ivory/75 leading-relaxed">You don’t have to figure it out alone.</p>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/free-training"
          class="inline-flex items-center justify-center rounded-full bg-gold-shine px-8 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all"
        >
          Start Your Journey Today
        </a>
        <a
          href="/book"
          class="inline-flex items-center justify-center rounded-full border border-gold/35 px-8 py-3.5 text-sm font-semibold text-ivory hover:bg-ivory/5 transition-colors"
        >
          Book Your Free Consultation
        </a>
      </div>
    </div>
  </section>
</GlobalLayout>
