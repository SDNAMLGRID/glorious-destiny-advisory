---
import GlobalLayout from "../layouts/GlobalLayout.astro";
import site from "../config.json";

const formEndpoint = site.formEndpoint?.trim();
const formAction = formEndpoint || `mailto:${site.email}`;
const formEncoding = formEndpoint ? "application/x-www-form-urlencoded" : "text/plain";
---

<GlobalLayout title="Contact" description="Contact Glorious Destiny Advisory—questions, media, and partnership.">
  <section class="relative bg-ink text-ivory py-20 sm:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-grain opacity-15 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-5 sm:px-8">
      <h1 class="font-display text-4xl sm:text-5xl font-semibold">Contact</h1>
      <p class="mt-6 text-ivory/75 font-sans text-lg">We’ll respond as soon as we can. For scheduling, use Book.</p>
    </div>
  </section>

  <section class="py-16 bg-ivory border-t border-ink/5">
    <div class="max-w-xl mx-auto px-5 sm:px-8">
      <dl class="font-sans space-y-1 text-body rounded-2xl border border-ink/10 bg-white p-8 shadow-card">
        <dt class="text-xs uppercase tracking-wider text-muted">Email</dt>
        <dd>
          <a href={`mailto:${site.email}`} class="text-gold-deep font-semibold hover:underline text-lg">{site.email}</a>
        </dd>
        {site.phone ? (
          <>
            <dt class="text-xs uppercase tracking-wider text-muted pt-6">Phone</dt>
            <dd>
              <a href={`tel:${String(site.phone).replace(/\D/g, "")}`} class="hover:underline text-lg">
                {site.phone}
              </a>
            </dd>
          </>
        ) : null}
        {site.linkedinUrl ? (
          <>
            <dt class="text-xs uppercase tracking-wider text-muted pt-6">LinkedIn</dt>
            <dd>
              <a
                href={site.linkedinUrl}
                class="text-gold-deep font-semibold hover:underline text-lg"
                target="_blank"
                rel="noopener noreferrer"
              >
                {site.principal} on LinkedIn
              </a>
            </dd>
          </>
        ) : null}
      </dl>

      <form class="mt-12 space-y-4" method="post" action={formAction} enctype={formEncoding}>
        <input type="hidden" name="source" value="contact" />
        <input type="text" name="name" placeholder="Name" class="w-full rounded-xl border border-ink/15 px-4 py-3 font-sans bg-white" />
        <input type="email" name="email" placeholder="Email" required class="w-full rounded-xl border border-ink/15 px-4 py-3 font-sans bg-white" />
        <textarea name="message" rows={5} placeholder="Message" class="w-full rounded-xl border border-ink/15 px-4 py-3 font-sans bg-white"></textarea>
        <button type="submit" class="w-full rounded-full bg-gold-shine py-3.5 font-bold text-ink shadow-lift hover:brightness-110 transition-all">
          Send message
        </button>
      </form>
      <p class="mt-6 text-xs text-muted font-sans leading-relaxed">
        Please avoid sending confidential account numbers, policy documents, or sensitive personal information through
        this form.
      </p>
    </div>
  </section>
</GlobalLayout>
