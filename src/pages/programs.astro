---
import GlobalLayout from "../layouts/GlobalLayout.astro";
import AdvisoryRule from "../components/AdvisoryRule.astro";
import site from "../config.json";

const programs = [
  {
    name: "Free Financial Education Session",
    desc: "A complimentary conversation to understand your priorities, surface blind spots, and outline realistic next steps—in plain language, with space for questions.",
    cta: "Book Free Session",
    href: "/book",
    tier: "Entry",
    featured: false,
  },
  {
    name: "Wealth & Leadership Mentorship",
    desc: "Rhythmic guidance for a season of growth: habits, mindset, stewardship, and follow-through—so financial progress and leadership maturity rise together.",
    cta: "Apply Now",
    href: "/apply",
    tier: "Growth",
    featured: true,
  },
  {
    name: "One-on-One Advisory",
    desc: "Tailored education and strategy support when your situation needs depth—goals, timeline, family dynamics, and values woven into one coherent plan.",
    cta: "Schedule Consultation",
    href: "/book",
    tier: "Personal",
    featured: false,
  },
];
---

<GlobalLayout title="Programs" description="Free education, mentorship, and one-on-one advisory with Glorious Destiny Advisory.">
  <section class="relative bg-ink text-ivory py-20 sm:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-dark-radial opacity-70 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-grain opacity-20 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <AdvisoryRule label="Programs" class="justify-center mb-8" />
      <h1 class="font-display text-4xl sm:text-5xl font-semibold leading-tight">How We Work Together</h1>
      <p class="mt-6 text-ivory/75 font-sans text-lg leading-relaxed">
        Start where you are. Each path meets you with clarity—not overwhelm—whether you need a single conversation or a
        longer arc of mentorship.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-sand/50 border-t border-ink/5">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 space-y-10">
      {programs.map((p) => (
        <article
          class:list={[
            "rounded-2xl border bg-ivory p-8 sm:p-10 flex flex-col md:flex-row md:items-center md:justify-between gap-8 transition-all duration-300 hover:-translate-y-0.5",
            p.featured ? "border-gold/40 shadow-goldring" : "border-ink/10 shadow-card hover:shadow-lift",
          ]}
        >
          <div class="flex-1">
            <p class="text-gold text-xs font-bold uppercase tracking-widest font-sans">{p.tier}</p>
            <h2 class="mt-2 font-display text-2xl font-semibold text-ink">{p.name}</h2>
            <p class="mt-3 font-sans text-muted leading-relaxed max-w-xl">{p.desc}</p>
          </div>
          <a
            href={p.href}
            class="shrink-0 inline-flex justify-center rounded-full bg-gold-shine px-8 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all"
          >
            {p.cta}
          </a>
        </article>
      ))}
    </div>
    <p class="text-center pb-12 font-sans text-sm text-muted bg-sand/50">{site.affiliation} · Educational context only.</p>
  </section>
</GlobalLayout>
