---
import GlobalLayout from "../layouts/GlobalLayout.astro";
import site from "../config.json";

const cal = site.calendlyUrl?.trim();
---

<GlobalLayout title="Book a Conversation" description="Schedule a complimentary educational conversation with Glorious Destiny Advisory—clarity, next steps, no pressure.">
  <section class="relative bg-ink text-ivory py-20 sm:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-grain opacity-15 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.22em] text-gold font-sans mb-3">Complimentary · Education-first</p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold">Book a conversation</h1>
      <p class="mt-6 text-ivory/75 font-sans text-lg leading-relaxed">
        Choose a time that works for you. This is a structured, calm dialogue—questions welcome, jargon optional, no hard
        sell.
      </p>
    </div>
  </section>

  <section class="py-16 bg-ivory">
    <div class="max-w-4xl mx-auto px-5 sm:px-8">
      {cal ? (
        <div class="rounded-2xl border border-ink/10 overflow-hidden shadow-lift bg-white min-h-[640px]">
          <iframe
            title="Schedule with Glorious Destiny Advisory"
            src={cal}
            class="w-full h-[720px] border-0"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="rounded-2xl border border-gold/25 bg-charcoal text-ivory p-10 sm:p-14 text-center min-h-[360px] flex flex-col items-center justify-center bg-grain">
          <p class="font-sans text-ivory/75 leading-relaxed max-w-md">
            Online booking is being finalized. Send a note and we’ll help you find a time for a free educational
            consultation.
          </p>
          <a
            href={`mailto:${site.email}?subject=Book%20a%20consultation`}
            class="mt-10 inline-flex rounded-full bg-gold-shine px-8 py-3.5 text-sm font-bold text-ink shadow-lift hover:brightness-110 transition-all"
          >
            Email to schedule
          </a>
        </div>
      )}

      <h2 class="mt-16 font-display text-2xl font-semibold text-ink">What to expect</h2>
      <ul class="mt-6 space-y-4 font-sans text-body/90">
        <li class="flex gap-3">
          <span class="text-gold shrink-0">◆</span>
          A few grounded questions about goals, timeline, and what “peace of mind” looks like in your real week—not a
          generic worksheet.
        </li>
        <li class="flex gap-3">
          <span class="text-gold shrink-0">◆</span>
          Plain-language education so you can compare options with context—not adrenaline.
        </li>
        <li class="flex gap-3">
          <span class="text-gold shrink-0">◆</span>
          Honest next steps when it is a mutual fit—and permission to pause when you need more time or it is not the right
          season.
        </li>
        <li class="flex gap-3">
          <span class="text-gold shrink-0">◆</span>
          Everything stays aligned with compliance: educational framing, no guarantees, no hype.
        </li>
      </ul>
    </div>
  </section>
</GlobalLayout>
