---
interface Props {
  label?: string;
  class?: string;
}
const { label = "Advisory", class: className = "" } = Astro.props;
---

<div class:list={["flex items-center justify-center gap-4", className]}>
  <span class="h-px w-8 sm:w-14 bg-gradient-to-r from-transparent to-gold/70" aria-hidden="true"></span>
  <span class="text-[0.65rem] sm:text-xs uppercase tracking-[0.35em] text-gold/90 font-sans font-semibold">{label}</span>
  <span class="h-px w-8 sm:w-14 bg-gradient-to-l from-transparent to-gold/70" aria-hidden="true"></span>
</div>
